<style>
  /* Carrusel móvil: ocultar scrollbar y cards estáticas (sin movimiento al deslizar) */
  @media (max-width: 767px) {
    .scrollbar-hide {
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .scrollbar-hide::-webkit-scrollbar {
      display: none;
    }
    /* Sin transiciones ni efectos hover en móvil: cards estáticas al deslizar */
    #productos .scrollbar-hide .group,
    #productos .scrollbar-hide .group * {
      transition: none !important;
    }
    /* Badge: rotación fija, no cambiar en hover */
    #productos .scrollbar-hide .group .rotate-12,
    #productos .scrollbar-hide .group:hover .rotate-12 {
      transform: rotate(12deg) !important;
    }
    #productos .scrollbar-hide .group .\-rotate-12,
    #productos .scrollbar-hide .group:hover .\-rotate-12 {
      transform: rotate(-12deg) !important;
    }
    /* Imagen: sin zoom en hover */
    #productos .scrollbar-hide .group img {
      transform: none !important;
    }
    /* Botón Ver detalles: siempre oculto en móvil para que no aparezca al tocar/deslizar */
    #productos .scrollbar-hide .group .absolute.z-20 {
      opacity: 0 !important;
    }
  }

  /* Animation keyframes for floating elements */
  @keyframes float {
    0% { transform: translateY(0px) translateX(0px); }
    50% { transform: translateY(-15px) translateX(10px); }
    100% { transform: translateY(0px) translateX(0px); }
  }
  
  @keyframes float-slow {
    0% { transform: translateY(0px) translateX(0px); }
    50% { transform: translateY(15px) translateX(-10px); }
    100% { transform: translateY(0px) translateX(0px); }
  }
  
  .animate-float {
    animation: float 8s ease-in-out infinite;
  }
  
  .animate-float-slow {
    animation: float-slow 12s ease-in-out infinite;
  }
</style>
