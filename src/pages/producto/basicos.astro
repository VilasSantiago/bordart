---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import Divider from '../../components/Divider.astro';

import productos from '../../data/productos.json';

const idsBasicos = [
  'basico-shirt-core-logo',
  'basico-shirt-full-statement',
  'basico-cap-sonrisol',
  'basico-docker-core',
  'basico-tote-daily',
];

const basicos = idsBasicos
  .map((id) => productos.find((p) => p.id === id))
  .filter((p): p is (typeof productos)[number] => Boolean(p));
---

<Layout>
  <Navigation />

  <div class="basicos-page relative isolate min-h-screen">
    <!-- Fondo fijo: imagen a pantalla completa + velo (el contenido va encima) -->
    <div class="basicos-fixed-bg pointer-events-none fixed left-0 right-0 bottom-0 top-16 z-[1]" aria-hidden="true">
      <img
        src="/assets/basicos/fondo-basicos.jpeg"
        alt=""
        class="absolute inset-0 h-full w-full object-cover object-center"
        loading="eager"
        decoding="async"
      />
      <div class="absolute inset-0 bg-white/68"></div>
    </div>

    <div class="relative z-[2]">
      <!-- Encabezado (texto sobre el fondo) -->
      <section
        id="basicos-hero"
        class="relative w-full flex flex-col items-center justify-center overflow-hidden px-4 pt-10 pb-10 md:pt-14 md:pb-12"
        aria-label="Encabezado Básicos"
      >
        <div class="w-full max-w-6xl mx-auto flex flex-col items-center justify-center text-center gap-4 md:gap-5 px-4 py-4">
          <div class="flex flex-col gap-3 md:gap-4">
            <h2 class="basicos-typing-look font-MiFuente font-bold text-xl md:text-3xl text-gray-900">
              Esenciales.
            </h2>
            <h3 class="basicos-typing-look font-MiFuente font-bold text-lg md:text-2xl text-gray-900 max-w-2xl leading-snug mx-auto">
              Piezas clave del día a día.
            </h3>
          </div>
        </div>
      </section>

      <section id="productos" class="px-4 pt-2 pb-8">
        <div class="max-w-4xl mx-auto p-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        {basicos.map((producto) => (
          <div class="border border-white/40 rounded-lg overflow-hidden shadow-lg hover:shadow-xl transition bg-white/90 backdrop-blur-md">
            <a href={`/producto/${producto.id}`}>
              <img src={producto.imagen[0]} alt={producto.nombre} class="w-full h-64 object-cover" />

              <div class="p-4 text-center">
                <h3 class="text-xl font-semibold">{producto.nombre}</h3>
                {typeof producto.precio === 'number' ? (
                  <p class="text-gray-700 font-semibold mt-2">
                    ${producto.precio.toLocaleString('es-AR')} <span class="text-sm font-normal text-gray-500">ARS</span>
                  </p>
                ) : (
                  <p class="text-red-500 font-semibold mt-2">{producto.precio}</p>
                )}
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>

    <div class="flex flex-col items-center justify-center text-center gap-4 p-4 pb-8">
      <h3 class="basicos-typing-look font-MiFuente font-bold text-xl md:text-3xl text-gray-900">
        Colección básica BORDART.
      </h3>
    </div>
      </section>

      <div class="relative z-[2] bg-white/50 backdrop-blur-[2px]">
        <Divider />
      </div>
      <Footer />
    </div>
  </div>
</Layout>

<style>
  /* El espaciador h-16 del nav ya deja hueco; el fondo fijo usa top-16 */

  /* Misma tipografía que "Próximamente capítulo..." en /producto/ropa (#typing-text),
     adaptada a fondo claro (contorno/sombra invertidos para texto oscuro) */
  .basicos-typing-look {
    font-family: 'MiFuente', sans-serif;
    text-align: center;
    margin: 0;
    -webkit-text-stroke: 0.5px rgba(0, 0, 0, 0.12);
    text-stroke: 0.5px rgba(0, 0, 0, 0.12);
    text-shadow: 0.5px 0.5px 0px rgba(0, 0, 0, 0.15);
  }
</style>
